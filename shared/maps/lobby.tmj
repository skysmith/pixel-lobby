        },
        {
          "id": 6,
          "name": "stop-bridger-shop",
          "type": "interact",
          "x": 768,
          "y": 416,
          "width": 128,
          "height": 96,
          "properties": [
            {
              "name": "kind",
              "type": "string",
              "value": "shop"
            },
            {
              "name": "title",
              "type": "string",
              "value": "Bridger Gear Shop"
            },
            {
              "name": "message",
              "type": "string",
              "value": "Bridger Gear's signature hammock system is built to be quick to carry and even quicker to set up, so you spend more time hanging out and less time fiddling with straps. When you're done, it packs into a sleek cross-body bag that works on the trail or in town. Includes a single hammock with straps and carabiners, supports up to 400 lbs (181 kg), and uses a 60% Nylon / 40% RPET Nylon blend. Made in China and designed by Bridger Gear in Bridgerland."
            },
            {
              "name": "cta",
              "type": "string",
              "value": "Open Bridger Gear"
            },
            {
              "name": "url",
              "type": "string",
              "value": "https://bridgergear.com"
            },
